<?xml version="1.0" encoding="utf-8"?><feed xmlns="http://www.w3.org/2005/Atom" ><generator uri="https://jekyllrb.com/" version="4.4.1">Jekyll</generator><link href="/Recipes/feed.xml" rel="self" type="application/atom+xml" /><link href="/Recipes/" rel="alternate" type="text/html" /><updated>2025-09-12T10:46:01+00:00</updated><id>/Recipes/feed.xml</id><title type="html">Rezeptebuch</title><subtitle>Ich mag Essen</subtitle><author><name>Exp</name></author><entry><title type="html">Feta Linguine</title><link href="/Recipes/feta-linguine" rel="alternate" type="text/html" title="Feta Linguine" /><published>2025-01-01T00:00:00+00:00</published><updated>2025-01-01T00:00:00+00:00</updated><id>/Recipes/feta-linguine</id><content type="html" xml:base="/Recipes/feta-linguine"><![CDATA[<h1 id="zutaten">Zutaten:</h1>
<ul>
  <li><span base="125"></span>g Linguine</li>
  <li>~<span base="125"></span>g Feta</li>
  <li><span base="75"></span>g Spinat</li>
  <li>Etwas Öl</li>
  <li>Gemüsebrühe</li>
  <li>Gewürze</li>
</ul>

<h1 id="rezept">Rezept</h1>
<ol>
  <li><span base="125"></span>g Linguine in ein Backform legen</li>
  <li><span base="125"></span>g Feta und <span base="75"></span>g Spinat auf die Linguine setzen</li>
  <li>Gewürze draufstreuen</li>
  <li>Öl drübergießen</li>
  <li>Mit Wasser befüllen bis die Linguine bedeckt sind</li>
  <li>Bei 200° Umluft in den Backofen bis die Nudeln durch sind</li>
</ol>]]></content><author><name>Exp</name></author><category term="nudeln" /><category term="backofen" /><summary type="html"><![CDATA[Zutaten: g Linguine ~g Feta g Spinat Etwas Öl Gemüsebrühe Gewürze]]></summary></entry></feed>